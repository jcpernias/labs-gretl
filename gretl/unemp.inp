set verbose off
set workdir ./build

open ../data/unemp.csv

ldiff PIBpm
diff unemp
gY = 100 * ld_PIBpm

# Time series plots
gnuplot d_unemp --time-series --with-lines --output=unemp-d_unemp.plt
gnuplot gY --time-series --with-lines --output=unemp-gY.plt


# Static regression
smpl 1982:1 2019:4
outfile unemp-static.txt
  ols d_unemp 0 gY
end outfile

# Time series plot and correlogram of the residuals
uhat = $uhat
gnuplot uhat --time-series --with-lines --output=unemp-uhat.plt
corrgm uhat 12 --acf-only --plot=unemp-corrgm-1.plt


# Distributed lags model
outfile unemp-dl.txt
  ols d_unemp 0 gY(0 to -5)
end outfile

scalar LAstar = -5
scalar LBstar = -5
scalar BICstar = $huge
scalar AICstar = $huge

outfile unemp-lags.txt
  loop for (L = LAstar; L <= 0; L += 1)
    ols d_unemp 0 gY(0 to L) --quiet
    printf "Lags = %d; AIC = %.2f, BIC = %.2f\n", -L, $aic, $bic
    if $bic < BICstar
       LBstar = L
       BICstar = $bic
    endif
    if $aic < AICstar
       LAstar = L
       AICstar = $aic
    endif
  endloop

  printf "\nL* = %d; AIC* = %.2f\n", -LAstar, AICstar
  printf "L* = %d; BIC* = %.2f\n", -LBstar, BICstar
end outfile

# Distributed lags model
outfile unemp-dlstar.txt
  ols d_unemp 0 gY(0 to -1)
end outfile

uhat = $uhat
gnuplot uhat --time-series --with-lines --output=unemp-uhat-dl.plt
corrgm uhat 12 --acf-only --plot=unemp-corrgm-dl.plt

# ARDL model
outfile unemp-ardl.txt
  ols d_unemp 0 gY(0 to -1) d_unemp(-1)
end outfile

uhat = $uhat
gnuplot uhat --time-series --with-lines --output=unemp-uhat-ardl.plt
corrgm uhat 12 --acf-only --plot=unemp-corrgm-ardl.plt
