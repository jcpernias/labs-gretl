set verbose off
set workdir "./build"

open "../data/piaac-es.csv"

salario = EARNHRBONUS
logs salario
mujer = GENDER_R == 2
edad = AGE_R
inmigr = BORNLANG > 2
otro_idioma = BORNLANG == 2 || BORNLANG == 4
educ_sec = EDCAT7 >= 2 && EDCAT7 <= 4
educ_sup = EDCAT7 >= 5
exper = C_Q09
square exper
antig = edad - D_Q05a1
pub = D_Q03 == 2
ong = D_Q03 == 3
contr_temp = D2_Q10_C == 2
contr_otro = D2_Q10_C == 3
parcial = D_Q10 < 35
cual_alta = ISCOSKIL4 == 1
cual_media = ISCOSKIL4 == 2 || ISCOSKIL4 == 3

list X1 = edad inmigr otro_idioma educ_sec educ_sup exper
list X2 = antig pub ong contr_temp contr_otro parcial cual_alta cual_media

# 3.1 Preparación de los datos
outfile wagegap-a.txt
  summary salario mujer X1 X2 --simple
end outfile

# 3.2 Brecha salarial no ajustada
outfile wagegap-b.txt
  ols l_salario 0 mujer --robust
end outfile

# 3.3 Brecha salarial ajustada
outfile wagegap-c.txt
  ols l_salario 0 mujer X1 sq_exper X2 --robust
end outfile

outfile wagegap-d.txt
  modtest --breusch-pagan --robust --quiet
end outfile

ols l_salario 0 mujer X1 sq_exper X2 --robust --quiet
outfile wagegap-e.txt
  omit X1 sq_exper X2 --quiet
end outfile


# 3.4 Otros contrastes
mujer_exper = mujer * exper
mujer_sq_exper = mujer * sq_exper
list X3 = mujer_exper mujer_sq_exper

outfile wagegap-f.txt
  ols l_salario 0 mujer X1 sq_exper X2 X3 --robust
end outfile

outfile wagegap-g.txt
  omit X3 --quiet
end outfile

ols l_salario 0 mujer X1 sq_exper X2 X3 --robust --quiet
outfile wagegap-h.txt
  restrict --quiet
    b[exper] + b[mujer_exper] = 0
    b[sq_exper] + b[mujer_sq_exper] = 0
  end restrict
end outfile
